# API Configuration
APP_NAME=GeoSync-ETL
APP_VERSION=0.1.0
DEBUG=True

# Satellite Provider (Planetary Computer doesn't strictly require a key for small use, 
# but it's good practice to have the variable ready)
STAC_API_URL=https://planetarycomputer.microsoft.com/api/stac/v1
PC_SDK_SUBSCRIPTION_KEY=your_key_here_if_applicable

# Processing Settings
TILE_SIZE=256
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000